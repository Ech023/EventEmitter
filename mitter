/**
 * 合法事件键类型：字符串 / Symbol
 */
export type EventType = string | symbol;

/**
 * 事件处理函数
 * @template T 事件负载类型
 */
export type Handler<T = unknown> = (event: T) => void;

/**
 * 单一事件对应的回调数组
 * @template T 事件负载类型
 */
export type EventHandlerList<T = unknown> = Array<Handler<T>>;

/**
 * 全局事件存储Map
 * key: 事件名
 * value: 对应事件回调列表
 * @template Events 事件映射约束 {事件名: 负载类型}
 */
export type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<keyof Events, EventHandlerList<unknown>>;

/**
 * 事件分组存储项（统一内部存储为unknown消除联合类型冲突）
 */
type GroupItem<Events extends Record<EventType, unknown>> = {
	type: keyof Events;
	handler: Handler<unknown>;
};

/**
 * 事件发射器标准接口
 * @template Events 事件类型约束映射
 */
export interface Emitter<Events extends Record<EventType, unknown>> {
	/** 只读原始事件存储Map */
	readonly all: EventHandlerMap<Events>;

	/**
	 * 注册普通事件监听
	 * @param type 事件名称
	 * @param handler 事件回调
	 * @returns 取消当前监听的函数
	 */
	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;

	/**
	 * 一次性事件监听，触发一次后自动解绑
	 * @param type 事件名称
	 * @param handler 事件回调
	 * @returns 取消当前监听的函数
	 */
	once<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;

	/**
	 * 移除指定事件监听
	 * @param type 事件名称
	 * @param handler 不传则清空该事件所有回调
	 */
	off<Key extends keyof Events>(type: Key, handler?: Handler<Events[Key]>): void;

	/**
	 * 触发事件（携带负载）
	 * @param type 事件名称
	 * @param event 事件负载数据
	 */
	emit<Key extends keyof Events>(type: Key, event: Events[Key]): void;

	/**
	 * 无参触发事件重载
	 * 仅当事件负载允许 undefined 时可用
	 * @param type 事件名称
	 */
	emit<Key extends keyof Events>(type: undefined extends Events[Key] ? Key : never): void;

	/**
	 * 获取事件有效监听器数量（过滤派发中占位undefined）
	 * @param type 事件名称
	 */
	listeners<Key extends keyof Events>(type: Key): number;

	/**
	 * 判断事件是否存在有效监听器
	 * @param type 事件名称
	 */
	hasListeners<Key extends keyof Events>(type: Key): boolean;

	/**
	 * 批量绑定一组事件，支持分组统一解绑
	 * @param bindKey 分组唯一标识
	 * @param handlers 批量事件配置列表
	 * @returns 解绑当前分组所有事件的函数
	 */
	binds<Key extends keyof Events>(bindKey: string, handlers: Array<{ type: Key; handler: Handler<Events[Key]> }>): void;

	/**
	 * 解绑指定分组下全部事件监听
	 * @param bindKey 分组唯一标识
	 */
	unbinds(bindKey: string): void;

	/**
	 * 清空全部事件监听（保留Map实例）
	 */
	clear(): void;

	/**
	 * 销毁实例，清空所有数据与分组
	 */
	destroy(): void;
}

/**
 * 创建轻量事件发射器实例
 * @param all 外部传入共享事件Map，可选
 * @returns Emitter 事件发射器
 * @example
 * @example
 * ```typescript
//不初始化注册类型
const emitter = mitt()
// listen to an event
emitter.on('foo', e => console.log('foo', e) )
// listen to all events
emitter.on('*', (type, e) => console.log(type, e) )
// fire an event
emitter.emit('foo', { a: 'b' })
// clearing all events
emitter.all.clear()
// working with handler references:
function onFoo() {}
emitter.on('foo', onFoo)   // listen
emitter.off('foo', onFoo)  // unlisten

//初始化注册类型
type Events = {
  foo: string;
  bar?: number;
};
const emitter = mitt<Events>(); // inferred as Emitter<Events>
emitter.on('foo', (e) => {}); // 'e' has inferred type 'string'
emitter.emit('foo', 42); // Error: Argument of type 'number' is not assignable to parameter of type 'string'. (2345)

 * ```
 */
export function mitt<Events extends Record<EventType, unknown>>(all?: EventHandlerMap<Events>): Emitter<Events> {
	// 事件存储容器，统一内部存储 Handler<unknown> 规避联合类型冲突
	const eventMap: EventHandlerMap<Events> = all ?? new Map();
	// 事件分组存储：key=分组标识，value=绑定事件列表
	const groups = new Map<string, GroupItem<Events>[]>();
	// 标记当前是否正在派发事件（防止遍历中splice导致数组错乱）
	const isDispatching = new Map<keyof Events, boolean>();

	/**
	 * 获取指定事件的回调数组，不存在则自动创建空数组
	 * @param type 事件名
	 * @returns 当前事件回调列表
	 */
	const getHandlers = <K extends keyof Events>(type: K): Handler<unknown>[] => {
		let handlers = eventMap.get(type);
		if (!handlers) {
			handlers = [];
			eventMap.set(type, handlers);
		}
		return handlers;
	};

	/**
	 * 移除单个事件回调，派发中做占位标记而非直接删除
	 * @param type 事件名
	 * @param handler 要移除的回调，不传清空整个事件
	 */
	const removeHandler = <K extends keyof Events>(type: K, handler?: Handler<Events[K]>) => {
		const handlers = getHandlers(type);
		if (!handler) {
			eventMap.delete(type);
			return;
		}
		const target = handler as Handler<unknown>;
		const idx = handlers.indexOf(target);
		if (idx === -1) return;
		if (isDispatching.get(type)) {
			handlers[idx] = undefined as any;
		} else {
			handlers.splice(idx, 1);
			if (handlers.length === 0) {
				eventMap.delete(type);
			}
		}
	};

	/**
	 * 派发完成后清理数组中undefined占位，删除空事件key
	 * @param type 事件名
	 */
	const cleanupDuringDispatch = <K extends keyof Events>(type: K) => {
		const handlers = eventMap.get(type);
		if (!handlers) return;
		let hasValid = false;
		for (let i = handlers.length - 1; i >= 0; i--) {
			if (handlers[i] === undefined) {
				handlers.splice(i, 1);
			} else {
				hasValid = true;
			}
		}
		if (!hasValid) {
			eventMap.delete(type);
		}
	};

	return {
		all: eventMap,

		on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>) {
			getHandlers(type).push(handler as Handler<unknown>);
		},

		once<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>) {
			const wrapper: Handler<Events[Key]> = evt => {
				removeHandler(type, wrapper);
				handler(evt);
			};
			getHandlers(type).push(wrapper as Handler<unknown>);
		},

		off<Key extends keyof Events>(type: Key, handler?: Handler<Events[Key]>) {
			removeHandler(type, handler);
		},

		emit<Key extends keyof Events>(type: Key, evt?: Events[Key]) {
			const handlers = getHandlers(type);
			if (handlers.length === 0) return;
			isDispatching.set(type, true);
			try {
				const payload = evt as unknown;
				for (const handler of handlers) {
					if (!handler) continue;
					try {
						handler(payload);
					} catch (err) {
						console.error(`[Emitter] Handler error on event "${String(type)}":`, err);
					}
				}
			} finally {
				cleanupDuringDispatch(type);
				isDispatching.delete(type);
			}
		},

		listeners<Key extends keyof Events>(type: Key) {
			return getHandlers(type).filter(Boolean).length;
		},

		hasListeners<Key extends keyof Events>(type: Key) {
			return this.listeners(type) > 0;
		},

		binds<Key extends keyof Events>(bindKey: string, bindList: Array<{ type: Key; handler: Handler<Events[Key]> }>) {
			this.unbinds(bindKey);
			const registered: GroupItem<Events>[] = [];
			for (const item of bindList) {
				const h = item.handler as Handler<unknown>;
				getHandlers(item.type).push(h);
				registered.push({
					type: item.type,
					handler: h,
				});
			}
			groups.set(bindKey, registered);
		},

		unbinds(bindKey: string) {
			const registered = groups.get(bindKey);
			if (!registered) return;
			for (const { type, handler } of registered) {
				removeHandler(type, handler as Handler<Events[keyof Events]>);
			}
			groups.delete(bindKey);
		},

		clear() {
			eventMap.clear();
			groups.clear();
		},

		destroy() {
			this.clear();
		},
	};
}
